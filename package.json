{
  "name": "dspf-designer",
  "displayName": "DSPF Designer",
  "description": "Visual designer for IBM i DSPF (Display Files) with drag-and-drop interface.",
  "version": "2.4.0",
  "publisher": "Balrocj",
  "icon": "media/icon-256.png",
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other",
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "ibm i",
    "ibmi",
    "as400",
    "iSeries",
    "dds",
    "dspf",
    "5250"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Balrocj/dspf-designer"
  },
  "homepage": "https://github.com/Balrocj/dspf-designer#readme",
  "bugs": {
    "url": "https://github.com/Balrocj/dspf-designer/issues"
  },
  "preview": true,
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.dspf",
    "onStartupFinished",
    "onLanguage:dds"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "dspfDesigner.editor",
        "displayName": "DSPF Designer",
        "selector": [
          {
            "filenamePattern": "*.dspf"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "dspfDesigner.openDesigner",
        "title": "Open Designer Mode",
        "category": "DSPF"
      },
      {
        "command": "dspfDesigner.exitDesigner",
        "title": "Exit Designer Mode",
        "category": "DSPF"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dspfDesigner.openDesigner",
          "when": "resourceExtname == .dspf || resourceFilename =~ /\\.[dD][sS][pP][fF]$/",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "dspfDesigner.openDesigner",
          "when": "(resourceExtname == .dspf || resourceFilename =~ /\\.[dD][sS][pP][fF]$/ || editorLangId == dds || editorLangId == dspf) && !dspfDesigner.isInDesignerMode",
          "group": "navigation"
        },
        {
          "command": "dspfDesigner.exitDesigner",
          "when": "(resourceExtname == .dspf || resourceFilename =~ /\\.[dD][sS][pP][fF]$/ || editorLangId == dds || editorLangId == dspf) && dspfDesigner.isInDesignerMode",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "dspfDesigner.openDesigner",
          "when": "(resourceExtname == .dspf || resourceFilename =~ /\\.[dD][sS][pP][fF]$/ || editorLangId == dds || editorLangId == dspf) && !dspfDesigner.isInDesignerMode"
        },
        {
          "command": "dspfDesigner.exitDesigner",
          "when": "(resourceExtname == .dspf || resourceFilename =~ /\\.[dD][sS][pP][fF]$/ || editorLangId == dds || editorLangId == dspf) && dspfDesigner.isInDesignerMode"
        }
      ]
    },
    "configuration": {
      "title": "DSPF Designer",
      "properties": {
        "dspfDesigner.openBehavior": {
          "type": "string",
          "enum": [
            "currentEditor",
            "newTab"
          ],
          "default": "currentEditor",
          "description": "Controls where Designer Mode opens: replace current editor or open as a new tab in the same editor group."
        },
        "dspfDesigner.saveMode": {
          "type": "string",
          "enum": [
            "manual",
            "automatic"
          ],
          "default": "manual",
          "description": "Controls save behavior in Designer and Source views: manual save with Save button or automatic save while editing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "test:preserve-regressions": "node test/run-preserve-regressions.js",
    "pretest": "npm run compile-tests && npm run compile && npm run test:preserve-regressions && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "codemirror": "^6.0.2",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  }
}
